# =============================================================
# RelayFlow - Environment Configuration Template
# =============================================================
# Copy this file to .env and fill in your values.
# .env is git-ignored. This file (.env.example) is safe to commit.

# -------------------------------------------------------------
# Application Ports
# -------------------------------------------------------------
GATEWAY_PORT=4001
WORKER_PORT=4002

# -------------------------------------------------------------
# Database (PostgreSQL)
# -------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password_here
DB_NAME=relayflow
DB_SYNCHRONIZE=false
DB_LOGGING=true

# -------------------------------------------------------------
# Redis
# -------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# -------------------------------------------------------------
# Authentication
# -------------------------------------------------------------
JWT_SECRET=change_me_in_production_use_a_long_random_string
JWT_EXPIRY=7d

# -------------------------------------------------------------
# Application
# -------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug
